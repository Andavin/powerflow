# ============================================================
# Powerflow stack — compose environment (example)
# ============================================================
# Copy to .env for `docker compose`. This file holds compose-level settings
# (image tags, host port, panel host/IP) plus any per-deploy overrides. The
# apps' actual configuration lives in config/config.yml — see
# config/config.example.yml. Keep your real .env private (it's gitignored).

# --- Images -----------------------------------------------------------------
# Pin a release tag instead of `latest` for reproducible deploys.
POWERFLOW_TAG=latest
COLLECTOR_TAG=latest
QUESTDB_TAG=latest

# --- Host ports -------------------------------------------------------------
POWERFLOW_PORT=3007       # web app  (-> container :3000)
QUESTDB_HTTP_PORT=9000    # QuestDB console/API on the host

# --- QuestDB storage --------------------------------------------------------
# A named docker volume by default. Set to an absolute host path to store the
# data elsewhere (e.g. QUESTDB_DATA=/mnt/storage/data/span).
QUESTDB_DATA=questdb-data

# --- Panel host mapping (required) ------------------------------------------
# The collector and web app reach the panel's MQTT broker by hostname so its
# TLS cert validates; compose maps that hostname to the panel's LAN IP inside
# the containers. PANEL_HOST must match `mqtt.server` in config/config.yml.
PANEL_HOST=span-xxxx-xxxxx.local
PANEL_IP=192.168.x.x

# --- Overrides (optional) ---------------------------------------------------
# Everything else is configured in config/config.yml. Any collector SPAN_* or
# web-app POWERFLOW_* variable set here OVERRIDES the matching key in that file
# — handy for keeping secrets out of the config file, or per-host tweaks:
#
#   POWERFLOW_PASSWORD=...
#   POWERFLOW_SESSION_SECRET=...      # openssl rand -hex 32
#   POWERFLOW_MQTT_PASSWORD=...
#   SPAN_MQTT_PASSWORD=...            # collector's copy of the broker password
